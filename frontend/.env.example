# ═══════════════════════════════════════════════════════════════
# DUST·N·RARE — Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!
# ═══════════════════════════════════════════════════════════════

# ─── SUPABASE ─────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── RESEND (Email notifications) ─────────────────────────────
# Get from: resend.com → API Keys (free tier: 3000 emails/month)
RESEND_API_KEY=re_your_api_key_here

# From address for Resend emails:
# - If you have a verified domain: orders@yourdomain.com
# - For testing only: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── ORDER CONFIG ─────────────────────────────────────────────
# WhatsApp number in format: country_code + number (no spaces or +)
ORDER_WHATSAPP=917033182211

# Your email where order notifications arrive
ORDER_EMAIL=dustnrare@gmail.com

# ─── ADMIN PANEL ──────────────────────────────────────────────
# Password for /admin page — must match what you set in Netlify env vars
ADMIN_PASSWORD=change_this_to_a_strong_password

# ─── GOOGLE ANALYTICS (Optional) ─────────────────────────────
# Get from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
